+static bool pyannote_cudnn_lstm_run_one_dir(
+    ggml_backend_cuda_context & ctx,
+    const ggml_tensor * x,
+    const ggml_tensor * w_ih,
+    const ggml_tensor * w_hh,
+    const ggml_tensor * b_ih,
+    const ggml_tensor * b_hh,
+    const int T,
+    const int in,
+    const int H,
+    const bool reverse,
+    float * dst,
+    const int dst_off) {
+
+    pyannote_cudnn_lstm_cache * cache = pyannote_cudnn_get_cache(w_ih->data);
+    if (!pyannote_cudnn_prepare(*cache, ctx, T, in, H, w_ih, w_hh, b_ih, b_hh)) {
+        return false;
+    }
+
+    ggml_cuda_pool_alloc<half> x_tmp(ctx.pool());
+    ggml_cuda_pool_alloc<half> y_tmp(ctx.pool());
+    ggml_cuda_pool_alloc<uint8_t> work(ctx.pool());
+    ggml_cuda_pool_alloc<half> hxcx(ctx.pool());
+
+    x_tmp.alloc((size_t) T * (size_t) in);
+    y_tmp.alloc((size_t) T * (size_t) H);
+    if (cache->workspace_bytes > 0) {
+        work.alloc(cache->workspace_bytes);
+    }
+    // Allocate hx, cx, hy, cy (each length H).
+    hxcx.alloc((size_t) 4 * (size_t) H);
+    half * hx = hxcx.get();
+    half * cx = hx + H;
+    half * hy = cx + H;
+    half * cy = hy + H;
+    CUDA_CHECK(cudaMemsetAsync(hx, 0, (size_t) H * sizeof(half), ctx.stream()));
+    CUDA_CHECK(cudaMemsetAsync(cx, 0, (size_t) H * sizeof(half), ctx.stream()));
+
+    {
+        const int n = T * in;
+        const int bs = 256;
+        const int gs = (n + bs - 1) / bs;
+        if (reverse) {
+            k_f32_tmajor_to_f16_cudnn_layout<true><<<gs, bs, 0, ctx.stream()>>>(T, in, (const float *) x->data, x_tmp.get());
+        } else {
+            k_f32_tmajor_to_f16_cudnn_layout<false><<<gs, bs, 0, ctx.stream()>>>(T, in, (const float *) x->data, x_tmp.get());
+        }
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    CUDNN_CHECK_RET(cudnnSetStream(cache->handle, ctx.stream()));
+    // Ensure the descriptor is built for this mini-batch.
+    if (ggml_cuda_pyannote_lstm_cudnn_verbose()) {
+        fprintf(stderr, "[cudnn] build+fwd T=%d in=%d H=%d reverse=%d\n", T, in, H, (int) reverse);
+    }
+    CUDNN_CHECK_RET(cudnnBuildRNNDynamic(cache->handle, cache->rnn_desc, 1));
+    cudnnStatus_t st = cudnnRNNForward(
+        cache->handle,
+        cache->rnn_desc,
+        CUDNN_FWD_MODE_INFERENCE,
+        cache->dev_seq_lengths,
+        cache->x_desc,
+        x_tmp.get(),
+        cache->y_desc,
+        y_tmp.get(),
+        cache->hx_desc,
+        hx,
+        hy,
+        cache->cx_desc,
+        cx,
+        cy,
+        cache->weight_space_bytes,
+        cache->weight_space_d,
+        cache->workspace_bytes,
+        cache->workspace_bytes ? work.get() : nullptr,
+        0,
+        nullptr);
+    if (st != CUDNN_STATUS_SUCCESS) {
+        fprintf(stderr,
+                "cuDNN error %d: %s (%s:%d: cudnnRNNForward) T=%d in=%d H=%d ws=%zu weight=%zu hx=%p cx=%p x=%p y=%p\n",
+                (int) st,
+                ggml_cudnn_get_error_string(st),
+                __FILE__,
+                __LINE__,
+                T,
+                in,
+                H,
+                (size_t) cache->workspace_bytes,
+                (size_t) cache->weight_space_bytes,
+                (void *) hx,
+                (void *) cx,
+                (void *) x_tmp.get(),
+                (void *) y_tmp.get());
+        return false;
+    }
+
+    // Convert + transpose output back to ggml layout.
+    {
+        const int n = T * H;
+        const int bs = 256;
+        const int gs = (n + bs - 1) / bs;
+        if (reverse) {
+            // reverse input produces output in reversed time order; flip back.
+            k_f16_cudnn_layout_to_f32_tmajor<true><<<gs, bs, 0, ctx.stream()>>>(T, H, y_tmp.get(), dst, dst_off);
+        } else {
+            k_f16_cudnn_layout_to_f32_tmajor<false><<<gs, bs, 0, ctx.stream()>>>(T, H, y_tmp.get(), dst, dst_off);
+        }
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    return true;
+}
