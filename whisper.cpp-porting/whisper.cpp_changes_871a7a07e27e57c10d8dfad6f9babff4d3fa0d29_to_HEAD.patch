+
+    for (let i = 0; i < streamingSegments.length; i++) {
+      const seg = streamingSegments[i];
+      if (seg.tokens && seg.tokens.length > 0) {
+        const tok = seg.tokens[0];
+        assert(typeof tok.t_dtw === "number", `Streaming segment ${i}: tokens have t_dtw field`);
+      }
+    }
