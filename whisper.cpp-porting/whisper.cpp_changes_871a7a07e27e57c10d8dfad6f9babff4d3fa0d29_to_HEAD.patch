+
+        assert(tok.t_dtw >= 0 && tok.t_dtw <= AUDIO_DURATION_CS, `Segment ${i} Token ${j}: t_dtw in range [0, ${AUDIO_DURATION_CS}] (got ${tok.t_dtw})`);
+      }
+
+      assert(hasNonZeroDtw, `Segment ${i}: at least one non-zero t_dtw (DTW was computed)`);
+    }
+  }
